<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Serilog.Enrichers.AspNetCore</id>
    <version>1.0.0</version>
    <authors>Laurentiu Stamate</authors>
    <owners>Laurentiu Stamate</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <licenseUrl>https://github.com/laurentiustamate94/serilog-enrichers-aspnetcore/blob/master/LICENSE</licenseUrl>
    <projectUrl>https://github.com/laurentiustamate94/serilog-enrichers-aspnetcore</projectUrl>
    <iconUrl>http://serilog.net/images/serilog-extension-nuget.png</iconUrl>
    <description>Enrich Serilog log events with properties from HttpContext in AspNetCore</description>
    <copyright>Copyright 2018</copyright>
    <tags>serilog aspnet aspnetcore httpcontext</tags>
    <repository url="https://github.com/laurentiustamate94/serilog-enrichers-aspnetcore" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.AspNetCore.Http.Abstractions" version="2.0.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.Mvc.Abstractions" version="2.0.3" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.WebUtilities" version="2.0.2" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="2.0.0" exclude="Build,Analyzers" />
        <dependency id="Serilog" version="2.6.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>